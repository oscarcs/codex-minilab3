{
  "name": "codex-minilab3",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "Use an Arturia MiniLab 3 as a software-emulated Codex Micro",
  "keywords": [
    "arturia",
    "chatgpt",
    "midi",
    "minilab"
  ],
  "os": [
    "darwin"
  ],
  "type": "module",
  "packageManager": "npm@11.14.1",
  "bin": {
    "codex-minilab3": "./bin/codex-minilab3"
  },
  "scripts": {
    "build:audio": "mkdir -p .build && xcrun swiftc -O -parse-as-library native/system-audio-spectrum.swift -o .build/system-audio-spectrum",
    "build:launcher": "mkdir -p .build && xcrun swiftc -O -parse-as-library -framework AppKit native/menu-bar-launcher.swift -o .build/menu-bar-launcher",
    "bridge": "bun src/cli.ts bridge",
    "launch": "bun src/cli.ts launch",
    "midi:list": "bun src/cli.ts midi list",
    "midi:monitor": "bun src/cli.ts midi monitor",
    "check": "bunx tsc -p tsconfig.json --noEmit",
    "test": "bun test test",
    "verify": "npm run build:audio && npm run build:launcher && npm run check && npm run test"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@julusian/midi": "3.6.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@types/node": "^22.15.0",
    "bun": "1.3.14",
    "typescript": "^5.8.0"
  }
}
